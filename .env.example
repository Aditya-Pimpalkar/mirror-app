# ─── Google Cloud ───────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=mirror-app-prod
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GCLOUD_REGION=us-central1

# ─── Gemini ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# ─── Firebase ───────────────────────────────────────────────
FIREBASE_PROJECT_ID=mirror-app-prod
FIREBASE_STORAGE_BUCKET=mirror-app-prod.appspot.com

# ─── Service URLs (local dev) ───────────────────────────────
PERSONA_SERVICE_URL=http://localhost:8080
PROFILE_SERVICE_URL=http://localhost:8081
SYNTHESIS_SERVICE_URL=http://localhost:8082
NOTIFICATION_SERVICE_URL=http://localhost:8083

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=change-this-in-production
SCHEDULER_SECRET=change-this-in-production
INTERNAL_SERVICE_SECRET=change-this-in-production

# ─── Feature Flags ──────────────────────────────────────────
ENABLE_CAMERA_EMOTION=true
ENABLE_TRUSTED_CIRCLE=false
ENABLE_VOICE_DIFFERENTIATION=true
