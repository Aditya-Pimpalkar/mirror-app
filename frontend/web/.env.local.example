# Mirror Web Frontend — Environment Variables
# Copy this to .env.local and fill in your values

# Service URLs (local dev)
NEXT_PUBLIC_PERSONA_SERVICE_URL=http://localhost:8080
NEXT_PUBLIC_PROFILE_SERVICE_URL=http://localhost:8081
NEXT_PUBLIC_SYNTHESIS_SERVICE_URL=http://localhost:8082

# Firebase Web Config
# Get these from: https://console.firebase.google.com/project/mirror-app-aditya/settings/general
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=mirror-app-aditya.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mirror-app-aditya
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=mirror-app-aditya.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=652269246406
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
